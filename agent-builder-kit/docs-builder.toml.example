schema_version = 1

[project]
name = "Example Product"
slug = "example-product"
mode = "new"
request = "ユーザーがやりたいことをここに書く"
summary = "このプロジェクトの要約"
primary_deliverable = "web_app"
target_users = ["internal_team"]

[workflow]
profile = "standard"
role_model = "four_role_default"
packs = ["obsidian_canvas_pack"]
review_required = true

[bootstrap]
seed_discovery_block = true
reference_seed = ["product_sense", "design", "attention_queue", "human_manual"]

[obsidian]
canvas_path = "docs/exec-plans/canvas/development-flow.canvas"
reference_dir = "docs/references"

[discovery]
confirmed = []
assumptions = []
non_goals = []
constraints = []

[generation]
output_root = "."
planning_root = "docs/exec-plans"
overwrite_policy = "safe_merge"
include_examples = false
